FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY ["ACC.sln", "./"]
COPY ["src/ACC.API/ACC.API.csproj", "src/ACC.API/"]
COPY ["src/ACC.Data/ACC.Data.csproj", "src/ACC.Data/"]
COPY ["src/ACC.ExternalClients/ACC.ExternalClients.csproj", "src/ACC.ExternalClients/"]
COPY ["src/ACC.Shared/ACC.Shared.csproj", "src/ACC.Shared/"]
COPY ["ACC.ServiceDefaults/ACC.ServiceDefaults.csproj", "ACC.ServiceDefaults/"]

RUN dotnet restore "src/ACC.API/ACC.API.csproj"

COPY . .

RUN dotnet publish "src/ACC.API/ACC.API.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app

EXPOSE 8080

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

ENV ASPNETCORE_URLS=http://+:8080
ENV ASPNETCORE_ENVIRONMENT=Production

COPY --from=build /app/publish .

ENTRYPOINT ["dotnet", "ACC.API.dll"]
