@using ACC.Shared.DTOs
@using System.Text.Json

<div class="form-check mb-2">
    <input class="form-check-input" type="checkbox" checked="@CurrentValue" @onchange="HandleChange" />
    <label class="form-check-label">@Label</label>
</div>

@code {
    [Parameter, EditorRequired] public BloqueLeccionUpsertDto Bloque { get; set; } = default!;
    [Parameter, EditorRequired] public string Property { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public Action<BloqueLeccionUpsertDto, string, bool>? OnChanged { get; set; }

    private bool CurrentValue => GetBool(Bloque, Property);

    private void HandleChange(ChangeEventArgs args)
    {
        OnChanged?.Invoke(Bloque, Property, (bool)(args.Value ?? false));
    }

    private static bool GetBool(BloqueLeccionUpsertDto bloque, string property)
    {
        try
        {
            using var document = JsonDocument.Parse(string.IsNullOrWhiteSpace(bloque.ConfiguracionJson) ? "{}" : bloque.ConfiguracionJson);
            return document.RootElement.TryGetProperty(property, out var value) && value.ValueKind == JsonValueKind.True;
        }
        catch (JsonException)
        {
            return false;
        }
    }
}
