@inherits LayoutComponentBase
@layout AccountLayout
@using System.Security.Claims
@using ACC.WebApp.Data
@using Microsoft.EntityFrameworkCore

@inject IServiceScopeFactory ScopeFactory

<section class="account-manage-page">
    <header class="account-manage-hero account-manage-card">
        <div class="account-manage-hero__copy">
            <div class="account-manage-hero__eyebrows" aria-label="Roles actuales del usuario">
                @foreach (var role in CurrentRoles)
                {
                    <span class="@GetRoleBadgeClass(role)">@role</span>
                }
            </div>
            <h1>Gestiona tu cuenta</h1>
            <p>Actualiza tu perfil, seguridad y preferencias desde un panel unificado.</p>
        </div>

        <div class="account-manage-hero__stats">
            <div class="account-manage-pill">
                <span>2FA</span>
                <strong>@TwoFactorStatus</strong>
            </div>
            <div class="account-manage-pill account-manage-pill--accent">
                <span>Email</span>
                <strong>@EmailStatus</strong>
            </div>
        </div>
    </header>

    <div class="account-manage-grid">
        <aside class="account-manage-sidebar account-manage-card">
            <div class="account-manage-sidebar__inner">
                <ManageNavMenu />
            </div>
        </aside>

        <main class="account-manage-main account-manage-card">
            <div class="account-manage-main__inner">
                @Body
            </div>
        </main>
    </div>
</section>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private bool isTwoFactorEnabled;
    private bool isEmailConfirmed;
    private string? loadedUserId;

    private IReadOnlyList<string> CurrentRoles =>
        HttpContext?.User?.FindAll(ClaimTypes.Role)
            .Select(claim => claim.Value)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray()
        ?? ["Cuenta ACC"];

    private string TwoFactorStatus => isTwoFactorEnabled ? "Activo" : "Inactivo";

    private string EmailStatus => isEmailConfirmed ? "Confirmado" : "Pendiente";

    protected override async Task OnParametersSetAsync()
    {
        if (HttpContext?.User?.Identity?.IsAuthenticated != true)
        {
            isTwoFactorEnabled = false;
            isEmailConfirmed = false;
            loadedUserId = null;
            return;
        }

        var userId = HttpContext.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (string.IsNullOrWhiteSpace(userId))
        {
            isTwoFactorEnabled = false;
            isEmailConfirmed = false;
            loadedUserId = null;
            return;
        }

        if (string.Equals(loadedUserId, userId, StringComparison.Ordinal))
        {
            return;
        }

        using var scope = ScopeFactory.CreateScope();
        var dbContext = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var userSnapshot = await dbContext.Users
            .AsNoTracking()
            .Where(user => user.Id == userId)
            .Select(user => new
            {
                user.TwoFactorEnabled,
                user.EmailConfirmed
            })
            .SingleOrDefaultAsync();

        if (userSnapshot is null)
        {
            isTwoFactorEnabled = false;
            isEmailConfirmed = false;
            loadedUserId = null;
            return;
        }

        isTwoFactorEnabled = userSnapshot.TwoFactorEnabled;
        isEmailConfirmed = userSnapshot.EmailConfirmed;
        loadedUserId = userId;
    }

    private static string GetRoleBadgeClass(string role)
    {
        var normalized = role.Trim().ToLowerInvariant();

        return normalized switch
        {
            "administrador" => "account-manage-hero__eyebrow account-manage-hero__eyebrow--admin",
            "docente" => "account-manage-hero__eyebrow account-manage-hero__eyebrow--teacher",
            "estudiante" => "account-manage-hero__eyebrow account-manage-hero__eyebrow--student",
            _ => "account-manage-hero__eyebrow account-manage-hero__eyebrow--default"
        };
    }
}
