@using Microsoft.AspNetCore.Identity
@using ACC.WebApp.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavigationManager

<nav class="account-nav" aria-label="Secciones de cuenta">
    <NavLink class="account-nav__link" href="Account/Manage" Match="NavLinkMatch.All">
        <i class="fas fa-user"></i><span>Perfil</span>
    </NavLink>

    <NavLink class="account-nav__link" href="Account/Manage/Email">
        <i class="fas fa-envelope"></i><span>Correo</span>
    </NavLink>

    <NavLink class="account-nav__link" href="Account/Manage/ChangePassword">
        <i class="fas fa-key"></i><span>Cambiar Contraseña</span>
    </NavLink>

    @if (hasExternalLogins)
    {
        <NavLink class="account-nav__link" href="Account/Manage/ExternalLogins">
            <i class="fas fa-external-link-alt"></i><span>Inicios de Sesión Externos</span>
        </NavLink>
    }

    <NavLink class="account-nav__link" href="Account/Manage/TwoFactorAuthentication">
        <i class="fas fa-shield-alt"></i><span>Autenticación de Dos Factores</span>
    </NavLink>

    <NavLink class="account-nav__link" href="Account/Manage/PersonalData">
        <i class="fas fa-id-card"></i><span>Datos Personales</span>
    </NavLink>

    <NavLink class="account-nav__link" href="Account/rol/Verificar">
        <i class="fas fa-user-tag"></i><span>Asignar Roles</span>
    </NavLink>
</nav>

<form action="Account/Logout" method="post" class="account-nav__logout-form">
    <AntiforgeryToken />
    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
    <button type="submit" class="account-nav__link account-nav__link--logout">
        <i class="fa-regular fa-rectangle-xmark"></i><span>Cerrar sesion</span>
    </button>
</form>

@code {
    private bool hasExternalLogins;
    private string currentUrl = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
        var relative = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        currentUrl = string.IsNullOrWhiteSpace(relative) ? string.Empty : relative;
    }
}
