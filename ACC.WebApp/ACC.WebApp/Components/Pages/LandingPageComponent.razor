@page "/"
@rendermode InteractiveServer
@layout LandingPageLayout
@using Microsoft.AspNetCore.Components.Authorization

@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

@if (_redirigiendo)
{
    <p class="landing-loading">Cargando tu resumen...</p>
}
else
{
    <div class="landing-page" id="inicio">
        <header class="landing-header">
            <div class="container nav-container">
                <a class="logo-container" href="#inicio" @onclick="CerrarMenuMovil">
                    <img src="ACC_icono.webp" alt="Logo de ACC" width="40" height="40">
                    <div class="logo-text">ACC</div>
                </a>

                <nav id="landing-nav" class="nav-links @(menuMovilAbierto ? "nav-links-open" : string.Empty)" aria-label="Navegacion principal">
                    <a href="#plataforma" class="nav-link" @onclick="CerrarMenuMovil">Plataforma</a>
                    <a href="#recorrido" class="nav-link" @onclick="CerrarMenuMovil">Recorrido</a>
                    <a href="#roles" class="nav-link" @onclick="CerrarMenuMovil">Roles</a>
                    <a href="#preguntas" class="nav-link" @onclick="CerrarMenuMovil">Preguntas</a>
                    <a href="#acceso" class="nav-link" @onclick="CerrarMenuMovil">Acceso</a>
                </nav>

                <button type="button"
                        class="mobile-menu-btn"
                        aria-label="Abrir menu"
                        aria-expanded="@menuMovilAbierto"
                        aria-controls="landing-nav"
                        @onclick="ToggleMenuMovil">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>
        </header>

        <section class="hero">
            <div class="hero-bg"></div>

            <div class="container hero-content">
                <div class="hero-copy">
                    <span class="hero-kicker">Aprendizaje guiado de C# en una sola plataforma</span>
                    <h1 class="hero-title">ACC conecta estudio, practica, seguimiento y aula sin salir del flujo.</h1>
                    <p class="hero-subtitle">
                        La plataforma ya integra resumen personal, agenda, guia por modulos, biblioteca por capitulos,
                        compilador en linea, evaluaciones y vistas de aula para estudiantes y docentes.
                    </p>

                    <div class="cta-buttons">
                        <a href="/Account/Register" class="btn btn-primary">Crear cuenta</a>
                        <a href="/Account/Login" class="btn btn-secondary">Iniciar sesion</a>
                        <a href="#plataforma" class="btn btn-ghost">Ver que incluye</a>
                    </div>

                    <div class="hero-chips" aria-label="Capacidades principales">
                        @foreach (var chip in heroChips)
                        {
                            <span class="hero-chip">@chip</span>
                        }
                    </div>
                </div>

                <div class="hero-panel">
                    <div class="hero-panel-card hero-panel-card--primary">
                        <span class="hero-panel-eyebrow">Flujo real dentro de ACC</span>
                        <ol class="hero-sequence">
                            @foreach (var step in heroSequence)
                            {
                                <li>
                                    <strong>@step.Title</strong>
                                    <span>@step.Description</span>
                                </li>
                            }
                        </ol>
                    </div>

                    <div class="hero-panel-card hero-panel-card--secondary">
                        <span class="hero-panel-eyebrow">Disponible hoy</span>
                        <div class="hero-matrix">
                            @foreach (var item in heroMatrix)
                            {
                                <article>
                                    <strong>@item.Title</strong>
                                    <span>@item.Description</span>
                                </article>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="feature-section" id="plataforma">
            <div class="container">
                <div class="section-heading">
                    <span class="section-kicker">Plataforma real</span>
                    <h2 class="section-title">Lo que si puedes hacer hoy en ACC</h2>
                    <p class="section-text">
                        Este contenido ya existe en la plataforma. No es una promesa futura ni una lista generica.
                    </p>
                </div>

                <div class="feature-grid">
                    @foreach (var feature in features)
                    {
                        <article class="feature-card">
                            <div class="feature-card-top">
                                <span class="feature-icon-wrap">
                                    <i class="@feature.Icon feature-icon"></i>
                                </span>
                                <span class="feature-tag">@feature.Tag</span>
                            </div>
                            <h3 class="feature-title">@feature.Title</h3>
                            <p class="feature-copy">@feature.Description</p>

                            @if (!string.IsNullOrWhiteSpace(feature.Link))
                            {
                                <a href="@feature.Link" class="feature-link">@feature.LinkLabel</a>
                            }
                            else
                            {
                                <span class="feature-note">@feature.LinkLabel</span>
                            }
                        </article>
                    }
                </div>
            </div>
        </section>

        <section class="journey-section" id="recorrido">
            <div class="container journey-layout">
                <div class="journey-copy">
                    <span class="section-kicker">Recorrido sugerido</span>
                    <h2 class="section-title section-title--left">Como se vive la plataforma cuando ya entras</h2>
                    <p class="section-text section-text--left">
                        ACC no se limita a mostrar contenido. Tiene un flujo claro: detectar pendientes, avanzar por la guia,
                        practicar, presentar evaluaciones y volver al resumen para medir progreso.
                    </p>
                </div>

                <div class="journey-rail">
                    @for (var index = 0; index < journeySteps.Length; index++)
                    {
                        var step = journeySteps[index];
                        <article class="journey-step">
                            <span class="journey-index">0@(index + 1)</span>
                            <div>
                                <h3>@step.Title</h3>
                                <p>@step.Description</p>
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>

        <section class="roles-section" id="roles">
            <div class="container">
                <div class="section-heading">
                    <span class="section-kicker">Roles y contexto</span>
                    <h2 class="section-title">La experiencia cambia segun el tipo de usuario</h2>
                </div>

                <div class="roles-grid">
                    @foreach (var role in roles)
                    {
                        <article class="role-card">
                            <div class="role-card-top">
                                <i class="@role.Icon"></i>
                                <h3>@role.Title</h3>
                            </div>
                            <p>@role.Description</p>
                            <ul class="role-list">
                                @foreach (var bullet in role.Bullets)
                                {
                                    <li>@bullet</li>
                                }
                            </ul>
                        </article>
                    }
                </div>
            </div>
        </section>

        <section class="faq-section" id="preguntas">
            <div class="container">
                <div class="section-heading">
                    <span class="section-kicker">Preguntas frecuentes</span>
                    <h2 class="section-title">Dudas comunes sobre el estado actual de ACC</h2>
                </div>

                <div class="faq-list">
                    @for (var index = 0; index < faqs.Length; index++)
                    {
                        var faq = faqs[index];
                        <article class="faq-item @(faqAbierta == index ? "active" : string.Empty)">
                            <button type="button"
                                    class="faq-question"
                                    aria-expanded="@(faqAbierta == index)"
                                    @onclick="() => ToggleFaq(index)">
                                <span>@faq.Question</span>
                                <i class="fa-solid fa-chevron-down faq-icon"></i>
                            </button>

                            <div class="faq-answer @(faqAbierta == index ? "faq-answer-open" : string.Empty)">
                                <p>@faq.Answer</p>
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>

        <section class="final-cta" id="acceso">
            <div class="final-cta-bg"></div>
            <div class="container final-cta-content">
                <span class="section-kicker section-kicker--center">Acceso</span>
                <h2 class="final-cta-title">Entra a ACC y empieza desde tu resumen, no desde una pantalla vacia.</h2>
                <p class="final-cta-text">
                    Si ya tienes cuenta, inicia sesion. Si no, registrate para acceder a la guia, la agenda,
                    la biblioteca, las evaluaciones y las vistas segun tu rol.
                </p>
                <div class="final-cta-actions">
                    <a href="/Account/Login" class="btn btn-primary">Entrar a la plataforma</a>
                    <a href="/Account/Register" class="btn btn-secondary">Crear cuenta nueva</a>
                </div>
            </div>
        </section>

        <footer class="landing-footer">
            <div class="container footer-shell">
                <div>
                    <div class="footer-logo">
                        <i class="fa-solid fa-code"></i> ACC
                    </div>
                    <p class="footer-text">Aprendiendo C# con Charp integra estudio, practica y seguimiento en un mismo lugar.</p>
                </div>

                <div class="footer-meta">
                    <span>Resumen</span>
                    <span>Guia</span>
                    <span>Agenda</span>
                    <span>Biblioteca</span>
                    <span>Aulas</span>
                    <span>Charp IA</span>
                </div>

                <p class="footer-legal">© @CurrentYear ACC. Todos los derechos reservados.</p>
            </div>
        </footer>
    </div>
}

@code {
    private bool estaAutenticado;
    private bool _redirigiendo;
    private bool menuMovilAbierto;
    private int? faqAbierta;

    private int CurrentYear => DateTime.UtcNow.Year;

    private readonly string[] heroChips =
    [
        "Resumen con progreso",
        "Agenda y tareas",
        "Guia modular",
        "Evaluaciones por avance",
        "Biblioteca por capitulos",
        "Compilador en linea",
        "Charp IA",
        "Aulas por rol"
    ];

    private readonly LandingMiniCard[] heroSequence =
    [
        new("Revisa tu resumen", "Ve progreso, tareas pendientes y evaluaciones vigentes desde un solo tablero."),
        new("Avanza por la guia", "Explora modulos, submodulos, temas, subtemas y lecciones."),
        new("Practica en contexto", "Las lecciones pueden incluir teoria, ejemplo, practica, actividad, compilador y video."),
        new("Vuelve a medir tu avance", "Agenda, resumen y evaluaciones te devuelven una vista clara de tu estado.")
    ];

    private readonly LandingMiniCard[] heroMatrix =
    [
        new("Guia", "Ruta por modulos y lecciones"),
        new("Biblioteca", "Capitulos con filtros"),
        new("Agenda", "Pendientes personales y asignados"),
        new("Examenes", "Submodulo y modulo"),
        new("Compilador", "Practica directa en C#"),
        new("Charp", "Vista dedicada y bloques de apoyo")
    ];

    private readonly LandingFeature[] features =
    [
        new("fa-solid fa-chart-line", "Resumen personal", "Panel para ver progreso general, evaluaciones activas y tareas pendientes del usuario autenticado.", "Panel principal", "/Resumen", "Ir al resumen"),
        new("fa-solid fa-calendar-check", "Agenda operativa", "Organiza tareas personales y asignadas, filtra por estado y detecta lo urgente sin cambiar de modulo.", "Seguimiento", "/Agenda", "Abrir agenda"),
        new("fa-solid fa-compass", "Guia de estudios", "Navega contenido jerarquico por modulos y lecciones, con progreso por subtema y evaluaciones ligadas al avance.", "Ruta guiada", "/Guia", "Ver guia"),
        new("fa-solid fa-code", "Practica y compilador", "Las lecciones pueden incluir compilador ACC, actividad interactiva y apoyo audiovisual en el mismo flujo.", "Practica", "/Compilador", "Abrir compilador"),
        new("fa-solid fa-book-bookmark", "Biblioteca por capitulos", "Explora documentacion, ejercicios y proyectos en un formato de capitulos con filtros y vista dedicada.", "Consulta", "/Biblioteca", "Entrar a biblioteca"),
        new("fa-solid fa-comment-nodes", "Charp IA", "Existe una vista dedicada para el asistente y tambien bloques de apoyo dentro de las lecciones.", "Asistencia", "/Charp-IA", "Abrir Charp"),
        new("fa-solid fa-school", "Aulas por rol", "La plataforma incluye vistas para estudiante y docente, con seguimiento de aula, tareas y contexto academico.", "Contexto academico", null, "Disponible segun rol"),
        new("fa-solid fa-user-gear", "Cuenta y seguridad", "Gestion de perfil, correo, autenticacion en dos pasos y configuracion visual de la cuenta.", "Acceso", "/Account/Manage", "Ir a cuenta")
    ];

    private readonly LandingMiniCard[] journeySteps =
    [
        new("Entrar al resumen", "El punto de inicio real es el resumen, donde convergen progreso, evaluaciones y tareas."),
        new("Usar agenda como radar", "La agenda permite priorizar pendientes personales y asignados antes de estudiar o entregar."),
        new("Estudiar desde la guia", "La guia organiza el contenido por modulos y baja hasta la leccion concreta que toca revisar."),
        new("Practicar y resolver", "Segun la leccion, puedes ver teoria, ejemplos, actividad interactiva, video o compilador."),
        new("Consultar biblioteca", "Cuando necesitas reforzar o buscar material, la biblioteca ofrece contenido por capitulos y filtros."),
        new("Volver a medir avance", "Examenes, progreso y tablero principal cierran el ciclo para seguir avanzando.")
    ];

    private readonly LandingRole[] roles =
    [
        new("fa-solid fa-user-graduate", "Estudiantes", "La experiencia del estudiante prioriza avance personal, contenido, tareas y seguimiento individual.", [
            "Resumen con progreso y evaluaciones",
            "Agenda para pendientes personales y asignados",
            "Guia y lecciones con practica",
            "Acceso a aulas y contexto del curso"
        ]),
        new("fa-solid fa-chalkboard-user", "Docentes", "La plataforma ya contempla vistas docentes para trabajo academico y control del aula.", [
            "Vista docente especializada",
            "Gestion de aula y contexto academico",
            "Seguimiento de tareas y actividad",
            "Apoyo a procesos de aprendizaje"
        ]),
        new("fa-solid fa-shield-halved", "Cuenta y acceso", "ACC usa autenticacion y roles para ajustar lo que cada usuario puede ver dentro de la plataforma.", [
            "Inicio de sesion y registro",
            "Gestion de correo y seguridad",
            "Autenticacion en dos pasos",
            "UI de cuenta adaptada al rol"
        ])
    ];

    private readonly LandingFaq[] faqs =
    [
        new("La plataforma es solo contenido teorico?", "No. La guia baja hasta lecciones que pueden renderizar teoria, ejemplo, practica, actividad interactiva, compilador y video."),
        new("ACC ya tiene seguimiento real del avance?", "Si. El resumen muestra progreso y evaluaciones, mientras la agenda concentra tareas personales y asignadas."),
        new("Necesito instalar algo para practicar?", "No necesariamente. El compilador ACC y gran parte del flujo funcionan dentro de la propia plataforma web."),
        new("Charp solo existe como idea o ya esta integrado?", "Ya existe una vista dedicada para Charp IA y tambien bloques de apoyo tipo Charp dentro de las lecciones."),
        new("Todos ven lo mismo dentro de la app?", "No. La experiencia cambia segun el rol; por ejemplo, hay vistas y accesos distintos para estudiantes, docentes y administracion.")
    ];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        estaAutenticado = auth.User.Identity?.IsAuthenticated ?? false;

        if (estaAutenticado)
        {
            _redirigiendo = true;
            Navigation.NavigateTo("/Resumen", forceLoad: true);
        }
    }

    private void ToggleMenuMovil() => menuMovilAbierto = !menuMovilAbierto;

    private void CerrarMenuMovil() => menuMovilAbierto = false;

    private void ToggleFaq(int indice)
    {
        faqAbierta = faqAbierta == indice ? null : indice;
    }

    private sealed record LandingFeature(
        string Icon,
        string Title,
        string Description,
        string Tag,
        string? Link,
        string LinkLabel);

    private sealed record LandingMiniCard(string Title, string Description);

    private sealed record LandingRole(string Icon, string Title, string Description, string[] Bullets);

    private sealed record LandingFaq(string Question, string Answer);
}
