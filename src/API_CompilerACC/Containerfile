FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY ["ACC.sln", "./"]
COPY ["src/API_CompilerACC/ACC.Compiler.csproj", "src/API_CompilerACC/"]
COPY ["ACC.ServiceDefaults/ACC.ServiceDefaults.csproj", "ACC.ServiceDefaults/"]

RUN dotnet restore "src/API_CompilerACC/ACC.Compiler.csproj"

COPY . .

RUN dotnet publish "src/API_CompilerACC/ACC.Compiler.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app

EXPOSE 8080

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

ENV ASPNETCORE_URLS=http://+:8080
ENV ASPNETCORE_ENVIRONMENT=Production

COPY --from=build /app/publish .

ENTRYPOINT ["dotnet", "ACC.Compiler.dll"]
