@page "/Account/ResetPasswordConfirmation"
<PageTitle>Reset password confirmation</PageTitle>

<div class="account-auth-page">
    <section class="account-auth-card account-auth-card--compact">
        <div class="account-auth-header">
            <span class="account-auth-kicker">Cuenta ACC</span>
            <h1>Confirmación de Restablecimiento de Contraseña</h1>
            <p>
                Tu contraseña ha sido restablecida. <a href="Account/Login">Haz clic aquí para iniciar sesión</a>.
            </p>
        </div>
    </section>
</div>
