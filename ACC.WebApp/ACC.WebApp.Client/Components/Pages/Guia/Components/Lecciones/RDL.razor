@rendermode InteractiveServer
@using ACC.Shared.DTOs
@inject IJSRuntime JS

@code {
    [Parameter] public LeccionDto Leccion { get; set; } = default!;

    private ModalActividades? ModalActividad;
    private string? urlActividadActual;

    private void ShowActivity(string url)
    {
        urlActividadActual = url;
        ModalActividad?.OpenModal();
    }

    private string? NivelBloomLeccion => Leccion.Bloques
        .OrderBy(x => x.Orden)
        .Select(x => x.NivelBloom)
        .FirstOrDefault(x => !string.IsNullOrWhiteSpace(x));

    private ValueTask NavegarAtrasAsync() => JS.InvokeVoidAsync("guiaNavigation.back");

    private ValueTask NavegarAdelanteAsync() => JS.InvokeVoidAsync("guiaNavigation.forward");
}

<ModalActividades Url="@urlActividadActual" @ref="ModalActividad" />

<div class="content leccion-container">
    <div class="leccion-toolbar">
        <div class="leccion-nav-arrows" aria-label="Navegacion de leccion">
            <button type="button" class="leccion-nav-arrow" @onclick="async () => await NavegarAtrasAsync()" title="Volver">
                <i class="fa-solid fa-arrow-left"></i>
            </button>
            <button type="button" class="leccion-nav-arrow" @onclick="async () => await NavegarAdelanteAsync()" title="Avanzar">
                <i class="fa-solid fa-arrow-right"></i>
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(NivelBloomLeccion))
    {
        <div class="nivel-bloom @NivelBloomLeccion"><p>Nivel de bloom: @NivelBloomLeccion</p></div>
    }

    @if (Leccion.Bloques.Count == 0)
    {
        <InfoComponent
            Title="Leccion sin bloques"
            Message="La leccion no tiene bloques configurados."
            StatusCode="204"
            ReturnUrl="/Guia" />
    }
    else
    {
        @foreach (var bloque in Leccion.Bloques.OrderBy(x => x.Orden))
        {
            <BloqueLeccionRenderer Bloque="@bloque" OnShowActividad="ShowActivity" />
        }
    }
</div>
