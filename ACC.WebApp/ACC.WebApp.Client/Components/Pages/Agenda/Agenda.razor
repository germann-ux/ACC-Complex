@page "/Agenda"
@rendermode InteractiveServer
@implements IDisposable
@using ACC.Shared.DTOs
@using ACC.Shared.Enums
@using ACC.Shared.Interfaces
@using ACC.WebApp.Client.Services
@using Microsoft.JSInterop
@using System.Net.Http.Headers
@using System.Security.Claims
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IApiJwtTokenService ApiJwtTokenService
@inject AgendaClientService AgendaClient
@inject AgendaRealtimeNotifier AgendaNotifier
@inject HttpClient cliente
@inject NavigationManager navegador
@inject IJSRuntime JS

<div class="agenda-page">
    @if (isAuthError)
    {
        <InfoComponent Title="Necesitas iniciar sesion"
                       Message="Necesitas iniciar sesion para ver tu agenda."
                       StatusCode="401"
                       ReturnUrl="@($"/Account/Login?returnUrl={Uri.EscapeDataString(navegador.Uri)}")" />
    }
    else if (isLoadingTareas)
    {
        <section class="agenda-card agenda-state" aria-live="polite">
            <p>
                <i class="fa-solid fa-circle-notch" aria-hidden="true"></i>
                Cargando agenda...
            </p>
        </section>
    }
    else
    {
        var asignadas = AsignadasFiltradas.ToList();
        var personales = PersonalesFiltradas.ToList();
        var totalResultados = asignadas.Count + personales.Count;
        var gruposPorVencimiento = GruposPorVencimiento.ToList();

        <section class="agenda-card agenda-header" aria-label="Encabezado de agenda">
            <div class="agenda-header-copy">
                <h1>Agenda</h1>
                <p>Visualiza lo urgente, organiza tus pendientes y ejecuta tu semana desde un solo lugar.</p>
            </div>

            <div class="agenda-header-actions">
                <button type="button" class="agenda-btn agenda-btn--primary" @onclick="AbrirModalCrear" disabled="@isActionBusy">
                    Nueva tarea
                </button>

                <a href="/Guia" class="agenda-btn agenda-btn--ghost">Practicas y examenes</a>
                <a href="/Aulas" class="agenda-btn agenda-btn--ghost">Aulas</a>
            </div>
        </section>

        <section class="agenda-card agenda-belt" aria-label="Metricas de agenda">
            <article class="agenda-pill">
                <span>Personales pendientes</span>
                <strong>@TotalPendientesPersonales</strong>
            </article>

            <article class="agenda-pill">
                <span>Asignadas pendientes</span>
                <strong>@TotalPendientesAsignadas</strong>
            </article>

            <article class="agenda-pill agenda-pill--warning">
                <span>Vencidas</span>
                <strong>@TotalVencidas</strong>
            </article>

            <article class="agenda-pill agenda-pill--success">
                <span>Completadas</span>
                <strong>@TotalCompletadas</strong>
            </article>

            <article class="agenda-pill agenda-pill--progress">
                <span>Progreso</span>
                <strong>@ProgresoGeneralPct%</strong>
            </article>
        </section>

        @if (pendingDeleteTask is not null)
        {
            <section class="agenda-undo-toast" aria-live="polite" role="status">
                <span>@MensajeDeshacerEliminar</span>
                <button type="button" @onclick="DeshacerEliminarPendienteAsync" disabled="@isActionBusy">Deshacer</button>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessageTareas))
        {
            <section class="agenda-card agenda-state agenda-state--error">
                <p>
                    <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
                    @errorMessageTareas
                </p>
            </section>
        }

        <section class="agenda-main-grid">
            <section class="agenda-card agenda-work" aria-label="Vista de trabajo">
                <div class="agenda-work-top">
                    <div>
                        <h2>Vista de trabajo</h2>
                        <div class="agenda-results"><strong>@ResultadoTexto(totalResultados)</strong></div>
                    </div>

                    <div class="agenda-group-switch" role="group" aria-label="Agrupacion de tareas">
                        <span>Agrupar por</span>
                        <button type="button"
                                class="agenda-group-btn @(agrupacionActiva == AgendaGrouping.Tipo ? "active" : string.Empty)"
                                aria-pressed="@(agrupacionActiva == AgendaGrouping.Tipo)"
                                @onclick="() => CambiarAgrupacionAsync(AgendaGrouping.Tipo)">
                            Tipo
                        </button>
                        <button type="button"
                                class="agenda-group-btn @(agrupacionActiva == AgendaGrouping.Vencimiento ? "active" : string.Empty)"
                                aria-pressed="@(agrupacionActiva == AgendaGrouping.Vencimiento)"
                                @onclick="() => CambiarAgrupacionAsync(AgendaGrouping.Vencimiento)">
                            Vencimiento
                        </button>
                    </div>
                </div>

                <p class="agenda-meta">
                    Filtro activo: <strong>@NombreFiltro(filtroActivo)</strong>. Prioriza por vencimiento y cierra lo mas urgente.
                </p>

                <div class="agenda-tabs" role="tablist" aria-label="Filtros de la vista de trabajo">
                    @foreach (var tab in Tabs)
                    {
                        <button type="button"
                                class="agenda-tab @(filtroActivo == tab.Filtro ? "active" : string.Empty)"
                                aria-pressed="@(filtroActivo == tab.Filtro)"
                                @onclick="() => CambiarFiltroAsync(tab.Filtro)">
                            @tab.Label
                            <span>@tab.Total</span>
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(actionMessage))
                {
                    <p class="agenda-action-message @(actionMessageOk ? "ok" : "error")">@actionMessage</p>
                }

                @if (agrupacionActiva == AgendaGrouping.Tipo)
                {
                    <div class="agenda-list-grid">
                        <section class="agenda-list-wrap">
                            <h3 class="agenda-list-title">Asignadas</h3>

                            @if (asignadas.Any())
                            {
                                <div class="agenda-list">
                                    @foreach (var item in asignadas)
                                    {
                                        <article class="agenda-item">
                                            <div class="agenda-item-copy">
                                                <h4>@item.Titulo</h4>

                                                @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                                                {
                                                    <p>@item.Descripcion</p>
                                                }

                                                <div class="agenda-item-due" title="@FechaTexto(item.FechaLimite)">Vence: @FechaHumana(item.FechaLimite)</div>
                                            </div>

                                            <div class="agenda-item-actions">
                                                <a href="/Guia" class="agenda-item-chip agenda-item-chip--link">Ir a practica</a>
                                            </div>
                                        </article>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="agenda-empty">
                                    <p>No hay tareas asignadas para este filtro.</p>
                                    <a class="agenda-empty-cta" href="/Guia">Ir a practicas y examenes</a>
                                </div>
                            }
                        </section>

                        <section class="agenda-list-wrap">
                            <h3 class="agenda-list-title">Personales</h3>

                            @if (personales.Any())
                            {
                                <div class="agenda-list">
                                    @foreach (var item in personales)
                                    {
                                        var esDestacada = highlightedPersonalId.HasValue && item.PersonalId == highlightedPersonalId;
                                        <article id="@ElementoHtmlId(item)" class="agenda-item @(esDestacada ? "agenda-item--highlight" : string.Empty)">
                                            <div class="agenda-item-copy">
                                                <h4>@item.Titulo</h4>

                                                @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                                                {
                                                    <p>@item.Descripcion</p>
                                                }

                                                <div class="agenda-item-due" title="@FechaTexto(item.FechaLimite)">Vence: @FechaHumana(item.FechaLimite)</div>
                                            </div>

                                            <div class="agenda-item-actions">
                                                @if (item.PersonalId is int tareaPersonalId)
                                                {
                                                    <button type="button"
                                                            class="agenda-item-chip"
                                                            @onclick="() => AlternarCompletadaPersonalAsync(tareaPersonalId)"
                                                            disabled="@isActionBusy">
                                                        @(item.Completada ? "Reabrir" : "Completar")
                                                    </button>

                                                    @if (!item.Completada)
                                                    {
                                                        <button type="button"
                                                                class="agenda-item-chip"
                                                                @onclick="() => PosponerTareaPersonalAsync(tareaPersonalId, 1)"
                                                                disabled="@isActionBusy">
                                                            Mañana
                                                        </button>

                                                        <button type="button"
                                                                class="agenda-item-chip"
                                                                @onclick="() => PosponerTareaPersonalAsync(tareaPersonalId, 7)"
                                                                disabled="@isActionBusy">
                                                            +7 dias
                                                        </button>
                                                    }

                                                    <button type="button"
                                                            class="agenda-item-chip agenda-item-chip--danger"
                                                            @onclick="() => SolicitarEliminarTareaPersonalAsync(tareaPersonalId)"
                                                            disabled="@isActionBusy">
                                                        Eliminar
                                                    </button>
                                                }
                                            </div>
                                        </article>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="agenda-empty">
                                    <p>No hay tareas personales para este filtro.</p>
                                    <button type="button" class="agenda-empty-cta" @onclick="AbrirModalCrear">Crear tarea</button>
                                </div>
                            }
                        </section>
                    </div>
                }
                else
                {
                    @if (gruposPorVencimiento.Any())
                    {
                        <div class="agenda-due-groups">
                            @foreach (var grupo in gruposPorVencimiento)
                            {
                                <section class="agenda-due-group">
                                    <h3>@grupo.Titulo <span>@grupo.Items.Count</span></h3>

                                    <div class="agenda-list">
                                        @foreach (var item in grupo.Items)
                                        {
                                            var esDestacada = highlightedPersonalId.HasValue && item.PersonalId == highlightedPersonalId;
                                            <article id="@ElementoHtmlId(item)" class="agenda-item @(esDestacada ? "agenda-item--highlight" : string.Empty)">
                                                <div class="agenda-item-copy">
                                                    <h4>@item.Titulo</h4>
                                                    <p class="agenda-item-source">@item.FuenteLabel</p>

                                                    @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                                                    {
                                                        <p>@item.Descripcion</p>
                                                    }

                                                    <div class="agenda-item-due" title="@FechaTexto(item.FechaLimite)">Vence: @FechaHumana(item.FechaLimite)</div>
                                                </div>

                                                <div class="agenda-item-actions">
                                                    @if (item.EsPersonal && item.PersonalId is int tareaPersonalId)
                                                    {
                                                        <button type="button"
                                                                class="agenda-item-chip"
                                                                @onclick="() => AlternarCompletadaPersonalAsync(tareaPersonalId)"
                                                                disabled="@isActionBusy">
                                                            @(item.Completada ? "Reabrir" : "Completar")
                                                        </button>

                                                        @if (!item.Completada)
                                                        {
                                                            <button type="button"
                                                                    class="agenda-item-chip"
                                                                    @onclick="() => PosponerTareaPersonalAsync(tareaPersonalId, 1)"
                                                                    disabled="@isActionBusy">
                                                                Mañana
                                                            </button>

                                                            <button type="button"
                                                                    class="agenda-item-chip"
                                                                    @onclick="() => PosponerTareaPersonalAsync(tareaPersonalId, 7)"
                                                                    disabled="@isActionBusy">
                                                                +7 dias
                                                            </button>
                                                        }

                                                        <button type="button"
                                                                class="agenda-item-chip agenda-item-chip--danger"
                                                                @onclick="() => SolicitarEliminarTareaPersonalAsync(tareaPersonalId)"
                                                                disabled="@isActionBusy">
                                                            Eliminar
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <a href="/Guia" class="agenda-item-chip agenda-item-chip--link">Ir a practica</a>
                                                    }
                                                </div>
                                            </article>
                                        }
                                    </div>
                                </section>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="agenda-empty agenda-empty--single">
                            <p>No hay tareas para este filtro en esta agrupacion.</p>
                            <button type="button" class="agenda-empty-cta" @onclick="AbrirModalCrear">Crear tarea</button>
                        </div>
                    }
                }
            </section>
        </section>
    }
</div>

@if (!isAuthError && !isLoadingTareas)
{
    <button type="button"
            class="agenda-fab @(isCreateModalOpen ? "is-hidden" : string.Empty)"
            @onclick="AbrirModalCrear"
            aria-label="Nueva tarea">
        <i class="fa-solid fa-plus" aria-hidden="true"></i>
        Nueva tarea
    </button>
}

@if (isCreateModalOpen)
{
    <div class="agenda-modal-backdrop" @onclick="CerrarModalCrear">
        <section class="agenda-card agenda-modal" role="dialog" aria-modal="true" aria-label="Nueva tarea" @onclick:stopPropagation="true">
            <header class="agenda-modal-head">
                <h3>Nueva tarea personal</h3>
                <button type="button" class="agenda-modal-close" @onclick="CerrarModalCrear" disabled="@isActionBusy" aria-label="Cerrar modal">
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                </button>
            </header>

            <div class="agenda-modal-form">
                <label>
                    <span>Titulo</span>
                    <input type="text" placeholder="Ejemplo: Terminar resumen de clase" @bind="nuevoTitulo" maxlength="120" />
                </label>

                <label>
                    <span>Descripcion</span>
                    <textarea placeholder="Notas breves para esta tarea" @bind="nuevaDescripcion" maxlength="500"></textarea>
                </label>

                <label>
                    <span>Fecha limite</span>
                    <input type="datetime-local" @bind="nuevaFechaLimiteLocal" />
                </label>
            </div>

            <footer class="agenda-modal-actions">
                <button type="button" class="agenda-btn agenda-btn--ghost" @onclick="CerrarModalCrear" disabled="@isActionBusy">Cancelar</button>
                <button type="button" class="agenda-btn agenda-btn--primary" @onclick="CrearTareaPersonalAsync" disabled="@isActionBusy">Crear tarea</button>
            </footer>
        </section>
    </div>
}

@code {
    private enum AgendaWorkFilter
    {
        Todo,
        Hoy,
        Proximas,
        Vencidas,
        Completadas,
        Asignadas,
        Personales,
        Recordatorios
    }

    private enum AgendaGrouping
    {
        Tipo,
        Vencimiento
    }

    private readonly record struct AgendaTaskItem(
        int? PersonalId,
        bool EsPersonal,
        string FuenteLabel,
        string Titulo,
        string? Descripcion,
        DateTime? FechaLimite,
        bool Completada);

    private readonly record struct AgendaTab(AgendaWorkFilter Filtro, string Label, int Total);

    private readonly record struct AgendaDueGroup(string Titulo, List<AgendaTaskItem> Items);

    private const string LocalStorageFiltroKey = "acc.agenda.filtro";
    private const string LocalStorageAgrupacionKey = "acc.agenda.agrupacion";
    private const int UndoDeleteWindowSeconds = 5;

    private List<TareaPersonalDto> tareasPersonales = [];
    private List<TareaAlumnoListadoDto> tareasAsignadas = [];

    private bool isLoadingTareas = true;
    private string? errorMessageTareas;
    private bool isAuthError;
    private string? userId;

    private AgendaWorkFilter filtroActivo = AgendaWorkFilter.Todo;
    private AgendaGrouping agrupacionActiva = AgendaGrouping.Tipo;

    private bool ignoreNextNotification;
    private bool isCreateModalOpen;
    private bool isActionBusy;
    private string? actionMessage;
    private bool actionMessageOk;

    private string nuevoTitulo = string.Empty;
    private string nuevaDescripcion = string.Empty;
    private DateTime nuevaFechaLimiteLocal = DateTime.Now.AddDays(1);

    private int? highlightedPersonalId;

    private TareaPersonalDto? pendingDeleteTask;
    private int? pendingDeletePersonalId;
    private CancellationTokenSource? pendingDeleteDelayCts;
    private bool isPendingDeleteCommitting;
    private int pendingDeleteSecondsLeft = UndoDeleteWindowSeconds;

    private bool preferenciasCargadas;

    private readonly CancellationTokenSource cts = new();

    private int TotalPendientesPersonales => tareasPersonales.Count(t => !(t.Completada ?? false));

    private int TotalPendientesAsignadas => tareasAsignadas.Count(t => !EsAsignadaCompletada(t));

    private int TotalCompletadas =>
        tareasPersonales.Count(t => t.Completada ?? false) +
        tareasAsignadas.Count(EsAsignadaCompletada);

    private int TotalTareas => tareasPersonales.Count + tareasAsignadas.Count;

    private int TotalVencidas =>
        tareasPersonales.Count(t => !(t.Completada ?? false) && EsVencida(t.TareaPersonalFechaLimite)) +
        tareasAsignadas.Count(t => !EsAsignadaCompletada(t) && EsVencida(t.FechaLimite));

    private int ProgresoGeneralPct => TotalTareas == 0
        ? 0
        : (int)Math.Round((double)TotalCompletadas * 100 / TotalTareas, MidpointRounding.AwayFromZero);

    private IEnumerable<AgendaTaskItem> TodosLosItems
    {
        get
        {
            foreach (var tarea in tareasAsignadas)
            {
                yield return MapAsignada(tarea);
            }

            foreach (var tarea in tareasPersonales)
            {
                yield return MapPersonal(tarea);
            }
        }
    }

    private IEnumerable<AgendaTaskItem> ItemsFiltrados => FiltrarItems(TodosLosItems);

    private IEnumerable<AgendaTaskItem> AsignadasFiltradas => ItemsFiltrados.Where(item => !item.EsPersonal);

    private IEnumerable<AgendaTaskItem> PersonalesFiltradas => ItemsFiltrados.Where(item => item.EsPersonal);

    private IReadOnlyList<AgendaTab> Tabs =>
    [
        new AgendaTab(AgendaWorkFilter.Todo, "Todo", TotalPorFiltro(AgendaWorkFilter.Todo)),
        new AgendaTab(AgendaWorkFilter.Hoy, "Hoy", TotalPorFiltro(AgendaWorkFilter.Hoy)),
        new AgendaTab(AgendaWorkFilter.Proximas, "Proximas", TotalPorFiltro(AgendaWorkFilter.Proximas)),
        new AgendaTab(AgendaWorkFilter.Vencidas, "Vencidas", TotalPorFiltro(AgendaWorkFilter.Vencidas)),
        new AgendaTab(AgendaWorkFilter.Completadas, "Completadas", TotalPorFiltro(AgendaWorkFilter.Completadas)),
        new AgendaTab(AgendaWorkFilter.Asignadas, "Asignadas", TotalPorFiltro(AgendaWorkFilter.Asignadas)),
        new AgendaTab(AgendaWorkFilter.Personales, "Personales", TotalPorFiltro(AgendaWorkFilter.Personales)),
        new AgendaTab(AgendaWorkFilter.Recordatorios, "Recordatorios", TotalPorFiltro(AgendaWorkFilter.Recordatorios))
    ];

    private IEnumerable<AgendaDueGroup> GruposPorVencimiento => CrearGruposPorVencimiento(ItemsFiltrados);

    private string MensajeDeshacerEliminar
        => $"Tarea eliminada. Puedes deshacer en {pendingDeleteSecondsLeft} {(pendingDeleteSecondsLeft == 1 ? "segundo" : "segundos")}.";

    protected override async Task OnInitializedAsync()
    {
        AgendaNotifier.Changed += HandleAgendaChanged;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            MostrarErrorAuth();
            return;
        }

        var accessToken = ApiJwtTokenService.TryCreateAccessToken(user);
        if (!string.IsNullOrWhiteSpace(accessToken))
        {
            cliente.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
        }

        userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value
            ?? user.FindFirst("sub")?.Value;

        await CargarTareasAsync(cts.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || preferenciasCargadas)
        {
            return;
        }

        preferenciasCargadas = true;
        await CargarPreferenciasAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CargarPreferenciasAsync()
    {
        try
        {
            var filtroGuardado = await JS.InvokeAsync<string?>("localStorage.getItem", LocalStorageFiltroKey);
            if (!string.IsNullOrWhiteSpace(filtroGuardado) && Enum.TryParse<AgendaWorkFilter>(filtroGuardado, out var filtro))
            {
                filtroActivo = filtro;
            }

            var agrupacionGuardada = await JS.InvokeAsync<string?>("localStorage.getItem", LocalStorageAgrupacionKey);
            if (!string.IsNullOrWhiteSpace(agrupacionGuardada) && Enum.TryParse<AgendaGrouping>(agrupacionGuardada, out var agrupacion))
            {
                agrupacionActiva = agrupacion;
            }
        }
        catch
        {
            // Ignore persistence errors.
        }
    }

    private async Task GuardarPreferenciasAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", LocalStorageFiltroKey, filtroActivo.ToString());
            await JS.InvokeVoidAsync("localStorage.setItem", LocalStorageAgrupacionKey, agrupacionActiva.ToString());
        }
        catch
        {
            // Ignore persistence errors.
        }
    }

    private async Task CambiarFiltroAsync(AgendaWorkFilter filtro)
    {
        if (filtroActivo == filtro)
        {
            return;
        }

        filtroActivo = filtro;
        await GuardarPreferenciasAsync();
    }

    private async Task CambiarAgrupacionAsync(AgendaGrouping agrupacion)
    {
        if (agrupacionActiva == agrupacion)
        {
            return;
        }

        agrupacionActiva = agrupacion;
        await GuardarPreferenciasAsync();
    }

    private async Task CargarTareasAsync(CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            MostrarErrorAuth();
            return;
        }

        isLoadingTareas = true;
        errorMessageTareas = null;

        try
        {
            var overview = await AgendaClient.GetOverviewAsync(token);
            tareasPersonales = overview.Personales;
            tareasAsignadas = overview.Asignadas;

            if (pendingDeletePersonalId.HasValue)
            {
                tareasPersonales = tareasPersonales
                    .Where(t => t.TareaPersonalId != pendingDeletePersonalId.Value)
                    .ToList();
            }

            if (!string.IsNullOrWhiteSpace(overview.ErrorMessage))
            {
                errorMessageTareas = overview.ErrorMessage;
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            MostrarErrorAuth();
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
            // Ignore cancellation on dispose.
        }
        catch (Exception ex)
        {
            errorMessageTareas = $"Error al cargar tareas: {ex.Message}";
        }
        finally
        {
            isLoadingTareas = false;
        }
    }

    private async Task RefrescarTareasAsync()
    {
        await CargarTareasAsync(cts.Token);
        ignoreNextNotification = true;
        AgendaNotifier.NotifyChanged();
        await InvokeAsync(StateHasChanged);
    }

    private void HandleAgendaChanged()
    {
        if (ignoreNextNotification)
        {
            ignoreNextNotification = false;
            return;
        }

        _ = InvokeAsync(async () =>
        {
            if (!isAuthError && !cts.IsCancellationRequested)
            {
                await CargarTareasAsync(cts.Token);
                StateHasChanged();
            }
        });
    }

    private IEnumerable<AgendaTaskItem> FiltrarItems(IEnumerable<AgendaTaskItem> items)
        => items
            .Where(item => CumpleFiltro(item, filtroActivo))
            .Where(item => !pendingDeletePersonalId.HasValue || !item.EsPersonal || item.PersonalId != pendingDeletePersonalId.Value)
            .OrderBy(item => item.FechaLimite.HasValue ? 0 : 1)
            .ThenBy(item => item.FechaLimite.HasValue ? ToLocal(item.FechaLimite.Value) : DateTime.MaxValue)
            .ThenBy(item => item.Titulo);

    private IEnumerable<AgendaDueGroup> CrearGruposPorVencimiento(IEnumerable<AgendaTaskItem> items)
    {
        var vencidas = new List<AgendaTaskItem>();
        var hoy = new List<AgendaTaskItem>();
        var proximas = new List<AgendaTaskItem>();
        var sinFecha = new List<AgendaTaskItem>();
        var completadas = new List<AgendaTaskItem>();

        foreach (var item in items)
        {
            if (item.Completada)
            {
                completadas.Add(item);
                continue;
            }

            if (!item.FechaLimite.HasValue)
            {
                sinFecha.Add(item);
                continue;
            }

            var fecha = ToLocal(item.FechaLimite.Value).Date;
            if (fecha < DateTime.Today)
            {
                vencidas.Add(item);
            }
            else if (fecha == DateTime.Today)
            {
                hoy.Add(item);
            }
            else
            {
                proximas.Add(item);
            }
        }

        if (vencidas.Count > 0)
        {
            yield return new AgendaDueGroup("Vencidas", vencidas);
        }

        if (hoy.Count > 0)
        {
            yield return new AgendaDueGroup("Hoy", hoy);
        }

        if (proximas.Count > 0)
        {
            yield return new AgendaDueGroup("Proximas", proximas);
        }

        if (sinFecha.Count > 0)
        {
            yield return new AgendaDueGroup("Sin fecha", sinFecha);
        }

        if (completadas.Count > 0)
        {
            yield return new AgendaDueGroup("Completadas", completadas);
        }
    }

    private int TotalPorFiltro(AgendaWorkFilter filtro)
        => TodosLosItems.Count(item => CumpleFiltro(item, filtro));

    private static bool CumpleFiltro(AgendaTaskItem item, AgendaWorkFilter filtro)
    {
        var fecha = item.FechaLimite.HasValue ? ToLocal(item.FechaLimite.Value).Date : (DateTime?)null;
        var hoy = DateTime.Today;

        return filtro switch
        {
            AgendaWorkFilter.Hoy => !item.Completada && fecha == hoy,
            AgendaWorkFilter.Proximas => !item.Completada && fecha.HasValue && fecha > hoy,
            AgendaWorkFilter.Vencidas => !item.Completada && fecha.HasValue && fecha < hoy,
            AgendaWorkFilter.Completadas => item.Completada,
            AgendaWorkFilter.Asignadas => !item.EsPersonal,
            AgendaWorkFilter.Personales => item.EsPersonal,
            AgendaWorkFilter.Recordatorios => !item.Completada && item.FechaLimite.HasValue,
            _ => true
        };
    }

    private static string NombreFiltro(AgendaWorkFilter filtro) => filtro switch
    {
        AgendaWorkFilter.Hoy => "Hoy",
        AgendaWorkFilter.Proximas => "Proximas",
        AgendaWorkFilter.Vencidas => "Vencidas",
        AgendaWorkFilter.Completadas => "Completadas",
        AgendaWorkFilter.Asignadas => "Asignadas",
        AgendaWorkFilter.Personales => "Personales",
        AgendaWorkFilter.Recordatorios => "Recordatorios",
        _ => "Todo"
    };

    private static string ResultadoTexto(int total)
        => total == 1 ? "1 resultado" : $"{total} resultados";

    private static string ElementoHtmlId(AgendaTaskItem item)
        => item.EsPersonal && item.PersonalId.HasValue
            ? $"personal-{item.PersonalId.Value}"
            : string.Empty;

    private void AbrirModalCrear()
    {
        actionMessage = null;
        isCreateModalOpen = true;
    }

    private void CerrarModalCrear()
    {
        if (isActionBusy)
        {
            return;
        }

        CerrarModalCrearInterno();
    }

    private void CerrarModalCrearForzado()
    {
        CerrarModalCrearInterno();
    }

    private void CerrarModalCrearInterno()
    {
        nuevoTitulo = string.Empty;
        nuevaDescripcion = string.Empty;
        nuevaFechaLimiteLocal = DateTime.Now.AddDays(1);
        isCreateModalOpen = false;
    }

    private async Task CrearTareaPersonalAsync()
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(nuevoTitulo))
        {
            SetActionMessage("El titulo es obligatorio.", ok: false);
            return;
        }

        isActionBusy = true;
        try
        {
            var dto = new TareaPersonalDto
            {
                TareaPersonalTitulo = nuevoTitulo.Trim(),
                TareaPersonalDescripcion = string.IsNullOrWhiteSpace(nuevaDescripcion) ? null : nuevaDescripcion.Trim(),
                TareaPersonalFechaLimite = DateTime.SpecifyKind(nuevaFechaLimiteLocal, DateTimeKind.Local).ToUniversalTime(),
                Completada = false
            };

            var response = await AgendaClient.CreatePersonalAsync(dto, cts.Token);
            if (response?.Success == true)
            {
                var nuevaId = response.Data?.TareaPersonalId;

                SetActionMessage("Tarea personal creada.", ok: true);
                CerrarModalCrearForzado();
                await RefrescarTareasAsync();

                if (nuevaId.HasValue)
                {
                    await EnfocarTareaPersonalAsync(nuevaId.Value);
                }
            }
            else
            {
                SetActionMessage(response?.Message ?? "No se pudo crear la tarea.", ok: false);
            }
        }
        catch (OperationCanceledException) when (cts.IsCancellationRequested)
        {
            // Ignore cancellation on dispose.
        }
        catch (Exception ex)
        {
            SetActionMessage($"Error al crear tarea: {ex.Message}", ok: false);
        }
        finally
        {
            isActionBusy = false;
        }
    }

    private async Task EnfocarTareaPersonalAsync(int tareaPersonalId)
    {
        highlightedPersonalId = tareaPersonalId;
        await InvokeAsync(StateHasChanged);

        await Task.Delay(80);
        NavegarAHtmlId($"personal-{tareaPersonalId}");

        _ = LimpiarResaltadoAsync(tareaPersonalId);
    }

    private async Task LimpiarResaltadoAsync(int tareaPersonalId)
    {
        await Task.Delay(1800);

        if (highlightedPersonalId == tareaPersonalId)
        {
            highlightedPersonalId = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void NavegarAHtmlId(string htmlId)
    {
        var uriBase = navegador.Uri.Split('#')[0];
        navegador.NavigateTo($"{uriBase}#{htmlId}", forceLoad: false, replace: true);
    }

    private async Task AlternarCompletadaPersonalAsync(int tareaPersonalId)
    {
        var tarea = tareasPersonales.FirstOrDefault(t => t.TareaPersonalId == tareaPersonalId);
        if (tarea is null)
        {
            return;
        }

        isActionBusy = true;
        try
        {
            var dto = CopiaTarea(tarea);
            dto.Completada = !(tarea.Completada ?? false);

            var response = await AgendaClient.UpdatePersonalAsync(dto, cts.Token);
            if (response?.Success == true)
            {
                SetActionMessage(dto.Completada == true ? "Tarea marcada como completada." : "Tarea reabierta.", ok: true);
                await RefrescarTareasAsync();
                highlightedPersonalId = tareaPersonalId;
                _ = LimpiarResaltadoAsync(tareaPersonalId);
            }
            else
            {
                SetActionMessage(response?.Message ?? "No se pudo actualizar la tarea.", ok: false);
            }
        }
        catch (OperationCanceledException) when (cts.IsCancellationRequested)
        {
            // Ignore cancellation on dispose.
        }
        catch (Exception ex)
        {
            SetActionMessage($"Error al actualizar tarea: {ex.Message}", ok: false);
        }
        finally
        {
            isActionBusy = false;
        }
    }

    private async Task PosponerTareaPersonalAsync(int tareaPersonalId, int dias)
    {
        var tarea = tareasPersonales.FirstOrDefault(t => t.TareaPersonalId == tareaPersonalId);
        if (tarea is null)
        {
            return;
        }

        isActionBusy = true;
        try
        {
            var baseLocal = tarea.TareaPersonalFechaLimite.HasValue
                ? ToLocal(tarea.TareaPersonalFechaLimite.Value)
                : DateTime.Now;

            if (baseLocal < DateTime.Now)
            {
                baseLocal = DateTime.Now;
            }

            var nuevaFechaLocal = baseLocal.AddDays(dias);
            var dto = CopiaTarea(tarea);
            dto.TareaPersonalFechaLimite = DateTime.SpecifyKind(nuevaFechaLocal, DateTimeKind.Local).ToUniversalTime();

            var response = await AgendaClient.UpdatePersonalAsync(dto, cts.Token);
            if (response?.Success == true)
            {
                SetActionMessage(dias == 1 ? "Tarea pospuesta para manana." : "Tarea pospuesta 7 dias.", ok: true);
                await RefrescarTareasAsync();
                highlightedPersonalId = tareaPersonalId;
                _ = LimpiarResaltadoAsync(tareaPersonalId);
            }
            else
            {
                SetActionMessage(response?.Message ?? "No se pudo posponer la tarea.", ok: false);
            }
        }
        catch (OperationCanceledException) when (cts.IsCancellationRequested)
        {
            // Ignore cancellation on dispose.
        }
        catch (Exception ex)
        {
            SetActionMessage($"Error al posponer tarea: {ex.Message}", ok: false);
        }
        finally
        {
            isActionBusy = false;
        }
    }

    private async Task SolicitarEliminarTareaPersonalAsync(int tareaPersonalId)
    {
        if (isActionBusy)
        {
            return;
        }

        if (pendingDeleteTask is not null && pendingDeletePersonalId.HasValue)
        {
            await ConfirmarEliminacionPendienteAsync(pendingDeletePersonalId.Value);
        }

        var tarea = tareasPersonales.FirstOrDefault(t => t.TareaPersonalId == tareaPersonalId);
        if (tarea is null)
        {
            return;
        }

        pendingDeleteTask = CopiaTarea(tarea);
        pendingDeletePersonalId = tareaPersonalId;

        pendingDeleteDelayCts?.Cancel();
        pendingDeleteDelayCts?.Dispose();
        pendingDeleteDelayCts = new CancellationTokenSource();
        pendingDeleteSecondsLeft = UndoDeleteWindowSeconds;

        tareasPersonales.RemoveAll(t => t.TareaPersonalId == tareaPersonalId);
        SetActionMessage("Tarea eliminada. Puedes deshacer.", ok: true);

        _ = ConfirmarEliminacionDiferidaAsync(tareaPersonalId, pendingDeleteDelayCts.Token);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmarEliminacionDiferidaAsync(int tareaPersonalId, CancellationToken token)
    {
        var expiraEn = DateTime.UtcNow.AddSeconds(UndoDeleteWindowSeconds);

        try
        {
            while (!token.IsCancellationRequested)
            {
                var restante = expiraEn - DateTime.UtcNow;
                var segundos = Math.Max(0, (int)Math.Ceiling(restante.TotalSeconds));

                if (segundos != pendingDeleteSecondsLeft)
                {
                    pendingDeleteSecondsLeft = segundos;
                    await InvokeAsync(StateHasChanged);
                }

                if (restante <= TimeSpan.Zero)
                {
                    break;
                }

                await Task.Delay(200, token);
            }

            if (token.IsCancellationRequested)
            {
                return;
            }

            await ConfirmarEliminacionPendienteAsync(tareaPersonalId);
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
            // Undo requested.
        }
    }

    private async Task ConfirmarEliminacionPendienteAsync(int tareaPersonalId)
    {
        if (isPendingDeleteCommitting)
        {
            return;
        }

        if (pendingDeleteTask is null || pendingDeletePersonalId != tareaPersonalId)
        {
            return;
        }

        isPendingDeleteCommitting = true;
        var tareaEliminada = CopiaTarea(pendingDeleteTask);
        LimpiarEliminacionPendiente(cancelDelay: false);

        try
        {
            var response = await AgendaClient.DeletePersonalAsync(tareaPersonalId, cts.Token);
            if (response?.Success == true)
            {
                SetActionMessage("Tarea eliminada definitivamente.", ok: true);
                ignoreNextNotification = true;
                AgendaNotifier.NotifyChanged();
            }
            else
            {
                RestaurarTareaPersonal(tareaEliminada);
                SetActionMessage(response?.Message ?? "No se pudo eliminar la tarea.", ok: false);
            }
        }
        catch (OperationCanceledException) when (cts.IsCancellationRequested)
        {
            // Ignore cancellation on dispose.
        }
        catch (Exception ex)
        {
            RestaurarTareaPersonal(tareaEliminada);
            SetActionMessage($"Error al eliminar tarea: {ex.Message}", ok: false);
        }
        finally
        {
            isPendingDeleteCommitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task DeshacerEliminarPendienteAsync()
    {
        if (pendingDeleteTask is null)
        {
            return Task.CompletedTask;
        }

        var restaurada = CopiaTarea(pendingDeleteTask);
        LimpiarEliminacionPendiente(cancelDelay: true);
        RestaurarTareaPersonal(restaurada);
        SetActionMessage("Eliminacion deshecha.", ok: true);

        return InvokeAsync(StateHasChanged);
    }

    private void RestaurarTareaPersonal(TareaPersonalDto tarea)
    {
        tareasPersonales.RemoveAll(t => t.TareaPersonalId == tarea.TareaPersonalId);
        tareasPersonales.Add(tarea);
    }

    private void LimpiarEliminacionPendiente(bool cancelDelay)
    {
        if (cancelDelay)
        {
            pendingDeleteDelayCts?.Cancel();
        }

        pendingDeleteDelayCts?.Dispose();
        pendingDeleteDelayCts = null;

        pendingDeleteTask = null;
        pendingDeletePersonalId = null;
        pendingDeleteSecondsLeft = UndoDeleteWindowSeconds;
    }

    private static TareaPersonalDto CopiaTarea(TareaPersonalDto tarea)
        => new()
        {
            TareaPersonalId = tarea.TareaPersonalId,
            TareaPersonalTitulo = tarea.TareaPersonalTitulo,
            TareaPersonalDescripcion = tarea.TareaPersonalDescripcion,
            Completada = tarea.Completada,
            TareaPersonalFechaLimite = tarea.TareaPersonalFechaLimite,
            IdUsuario = tarea.IdUsuario,
            IdAgenda = tarea.IdAgenda
        };

    private void SetActionMessage(string text, bool ok)
    {
        actionMessage = text;
        actionMessageOk = ok;
    }

    private static AgendaTaskItem MapPersonal(TareaPersonalDto tarea)
        => new(
            PersonalId: tarea.TareaPersonalId,
            EsPersonal: true,
            FuenteLabel: "Personal",
            Titulo: string.IsNullOrWhiteSpace(tarea.TareaPersonalTitulo) ? "(Sin titulo)" : tarea.TareaPersonalTitulo.Trim(),
            Descripcion: string.IsNullOrWhiteSpace(tarea.TareaPersonalDescripcion) ? null : tarea.TareaPersonalDescripcion.Trim(),
            FechaLimite: tarea.TareaPersonalFechaLimite,
            Completada: tarea.Completada ?? false);

    private static AgendaTaskItem MapAsignada(TareaAlumnoListadoDto tarea)
        => new(
            PersonalId: null,
            EsPersonal: false,
            FuenteLabel: "Asignada",
            Titulo: string.IsNullOrWhiteSpace(tarea.Titulo) ? "(Sin titulo)" : tarea.Titulo,
            Descripcion: string.IsNullOrWhiteSpace(tarea.EnunciadoCorto) ? null : tarea.EnunciadoCorto,
            FechaLimite: tarea.FechaLimite,
            Completada: EsAsignadaCompletada(tarea));

    private static bool EsAsignadaCompletada(TareaAlumnoListadoDto tarea)
        => tarea.Estado == TareaEstado.Completada
           || tarea.EstadoEntrega == TareaEstadoEntrega.Calificada
           || tarea.EstadoEntrega == TareaEstadoEntrega.Entregada
           || tarea.EstadoEntrega == TareaEstadoEntrega.EntregadaTarde;

    private static bool EsVencida(DateTime? fecha)
    {
        if (!fecha.HasValue)
        {
            return false;
        }

        return ToLocal(fecha.Value).Date < DateTime.Today;
    }

    private static bool EsVencida(DateTime fecha)
        => ToLocal(fecha).Date < DateTime.Today;

    private static DateTime ToLocal(DateTime fecha)
        => fecha.Kind == DateTimeKind.Utc ? fecha.ToLocalTime() : fecha;

    private static string FechaTexto(DateTime? fecha)
        => fecha.HasValue ? ToLocal(fecha.Value).ToString("dd/MM/yyyy HH:mm") : "Sin fecha";

    private static string FechaHumana(DateTime? fecha)
    {
        if (!fecha.HasValue)
        {
            return "Sin fecha";
        }

        var local = ToLocal(fecha.Value);
        var dias = (local.Date - DateTime.Today).Days;

        return dias switch
        {
            0 => "Hoy",
            1 => "Mañana",
            -1 => "Ayer",
            < 0 => $"Hace {Math.Abs(dias)} dias",
            <= 7 => $"En {dias} dias",
            _ => local.ToString("dd/MM/yyyy")
        };
    }

    private void MostrarErrorAuth()
    {
        isAuthError = true;
        errorMessageTareas = "Usuario no autenticado.";
