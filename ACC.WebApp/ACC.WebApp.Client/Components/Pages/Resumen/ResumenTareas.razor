@using ACC.Shared.DTOs
@using ACC.Shared.Enums
@rendermode InteractiveServer

<div class="resumen-tareas card">
    <div class="tasks-header">
        <h2>Tareas Pendientes</h2>
        <a class="tasks-agenda-link" href="/Agenda">Ver en agenda</a>
    </div>

    @if (IsLoading)
    {
        <p>Cargando tareas...</p>
    }
    else
    {
        var tareasResumen = ObtenerTareasResumen();
        var asignadasPendientes = TotalAsignadasPendientes;
        var personalesPendientes = TotalPersonalesPendientes;

        if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <p class="error-state">@ErrorMessage</p>
        }

        <div class="tasks-metrics-grid" aria-label="Resumen de tareas pendientes">
            <article class="task-metric-card task-metric-card--overdue">
                <p class="task-metric-label">Vencidas</p>
                <p class="task-metric-value">@TotalVencidas</p>
                <p class="task-metric-meta">Requieren atención</p>
            </article>

            <article class="task-metric-card task-metric-card--today">
                <p class="task-metric-label">Para hoy</p>
                <p class="task-metric-value">@TotalParaHoy</p>
                <p class="task-metric-meta">Prioridad del día</p>
            </article>

            <article class="task-metric-card task-metric-card--upcoming">
                <p class="task-metric-label">Próximas</p>
                <p class="task-metric-value">@TotalProximas</p>
                <p class="task-metric-meta">Siguientes entregas</p>
            </article>
        </div>

        <div class="tasks-counts">
            <span class="task-chip">Asignadas pendientes: @asignadasPendientes</span>
            <span class="task-chip">Personales pendientes: @personalesPendientes</span>
        </div>

        @if (tareasResumen.Count == 0)
        {
            <p class="empty-state">No tienes tareas pendientes.</p>
        }
        else
        {
            <section class="tasks-priority-panel">
                <h3>Atención inmediata</h3>
                <div class="tasks-priority-list">
                    @foreach (var tarea in tareasResumen)
                    {
                        <article class="task-summary-item @ObtenerClaseUrgencia(tarea.Urgencia)">
                            <div>
                                <p class="task-title">@tarea.Titulo</p>
                                <div class="task-meta-row">
                                    <span class="task-badge">@tarea.Tipo</span>
                                    <span class="task-badge">@tarea.Estado</span>
                                    <span class="task-badge">@tarea.FechaTexto</span>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </section>
        }
    }
</div>

@code {
    [Parameter] public TareasPendientesResumenDto? TareasPendientes { get; set; }
    [Parameter] public List<TareaAlumnoListadoDto> TareasAsignadas { get; set; } = new();
    [Parameter] public List<TareaPersonalDto> TareasPersonales { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public int MaxAsignadas { get; set; } = 5;

    private int TotalAsignadasPendientes => TareasAsignadas.Count(EsPendiente);

    private int TotalPersonalesPendientes => TareasPersonales.Count(EsPendiente);

    private int TotalVencidas => TareasPendientes?.Vencidas ?? ContarPorUrgencia(TareaResumenUrgencia.Vencida);

    private int TotalParaHoy => TareasPendientes?.ParaHoy ?? ContarPorUrgencia(TareaResumenUrgencia.Hoy);

    private int TotalProximas => TareasPendientes?.Proximas ?? ContarPorUrgencia(TareaResumenUrgencia.Proxima);

    private List<TareaResumenItem> ObtenerTareasResumen()
    {
        var asignadas = TareasAsignadas
            .Where(EsPendiente)
            .Select(tarea => new TareaResumenItem(
                Titulo: TextoOrDefault(tarea.Titulo),
                Tipo: "Asignada",
                Estado: EstadoTexto(tarea),
                Fecha: tarea.FechaLimite,
                FechaTexto: $"Vence {FechaCorta(tarea.FechaLimite)}",
                Urgencia: ClasificarFecha(tarea.FechaLimite)));

        var personales = TareasPersonales
            .Where(EsPendiente)
            .Select(tarea => new TareaResumenItem(
                Titulo: TextoOrDefault(tarea.TareaPersonalTitulo),
                Tipo: "Personal",
                Estado: "Pendiente",
                Fecha: tarea.TareaPersonalFechaLimite,
                FechaTexto: FechaTextoPersonal(tarea.TareaPersonalFechaLimite),
                Urgencia: ClasificarFecha(tarea.TareaPersonalFechaLimite)));

        return asignadas
            .Concat(personales)
            .OrderBy(tarea => tarea.Urgencia)
            .ThenBy(tarea => tarea.Fecha ?? DateTime.MaxValue)
            .ThenBy(tarea => tarea.Titulo)
            .Take(Math.Max(0, MaxAsignadas))
            .ToList();
    }

    private int ContarPorUrgencia(TareaResumenUrgencia urgencia)
    {
        var asignadas = TareasAsignadas
            .Where(EsPendiente)
            .Count(tarea => ClasificarFecha(tarea.FechaLimite) == urgencia);

        var personales = TareasPersonales
            .Where(EsPendiente)
            .Count(tarea => ClasificarFecha(tarea.TareaPersonalFechaLimite) == urgencia);

        return asignadas + personales;
    }

    private static bool EsPendiente(TareaAlumnoListadoDto tarea)
        => tarea.Estado != TareaEstado.Completada
           && tarea.EstadoEntrega != TareaEstadoEntrega.Calificada
           && tarea.EstadoEntrega != TareaEstadoEntrega.Entregada
           && tarea.EstadoEntrega != TareaEstadoEntrega.EntregadaTarde;

    private static bool EsPendiente(TareaPersonalDto tarea)
        => tarea.Completada != true;

    private static TareaResumenUrgencia ClasificarFecha(DateTime fecha)
        => ClasificarFecha((DateTime?)fecha);

    private static TareaResumenUrgencia ClasificarFecha(DateTime? fecha)
    {
        if (!fecha.HasValue)
            return TareaResumenUrgencia.SinFecha;

        var fechaLocal = fecha.Value.ToLocalTime().Date;
        var hoy = DateTime.Today;

        if (fechaLocal < hoy)
            return TareaResumenUrgencia.Vencida;

        if (fechaLocal == hoy)
            return TareaResumenUrgencia.Hoy;

        return TareaResumenUrgencia.Proxima;
    }

    private static string ObtenerClaseUrgencia(TareaResumenUrgencia urgencia)
        => urgencia switch
        {
            TareaResumenUrgencia.Vencida => "task-summary-item--overdue",
            TareaResumenUrgencia.Hoy => "task-summary-item--today",
            _ => "task-summary-item--upcoming"
        };

    private static string EstadoTexto(TareaAlumnoListadoDto tarea)
    {
        if (tarea.EstadoEntrega == TareaEstadoEntrega.DevueltaParaCorreccion)
            return "Devuelta";

        return tarea.Estado switch
        {
            TareaEstado.NoIniciada => "No iniciada",
            TareaEstado.EnProgreso => "En progreso",
            _ => tarea.Estado.ToString()
        };
    }

    private static string FechaCorta(DateTime fecha)
        => fecha.ToLocalTime().ToString("dd MMM");

    private static string FechaTextoPersonal(DateTime? fecha)
        => fecha.HasValue ? $"Vence {FechaCorta(fecha.Value)}" : "Sin fecha";

    private static string TextoOrDefault(string? texto)
        => string.IsNullOrWhiteSpace(texto) ? "(Sin título)" : texto.Trim();

    private sealed record TareaResumenItem(
        string Titulo,
        string Tipo,
        string Estado,
        DateTime? Fecha,
        string FechaTexto,
        TareaResumenUrgencia Urgencia);

    private enum TareaResumenUrgencia
    {
        Vencida = 0,
        Hoy = 1,
        Proxima = 2,
        SinFecha = 3
    }
}
