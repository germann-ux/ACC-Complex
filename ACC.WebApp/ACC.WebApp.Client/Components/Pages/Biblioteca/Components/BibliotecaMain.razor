@* BibliotecaMain.razor *@

@page "/Biblioteca"

@rendermode InteractiveServer

@using ACC.Shared.DTOs
@using ACC.Shared.Core
@using ACC.WebApp.Client.Components.Pages.Biblioteca.Components
@using ACC.WebApp.Client.Services

@inject BibliotecaClientService BibliotecaService

<div class="content biblioteca-app-container">

    <main class="biblioteca-main-content">

        <div class="biblioteca-header">

            <div class="biblioteca-header-hero">
@*                 <div class="biblioteca-header-icon-wrap" aria-hidden="true">
                    <i class="fa-solid fa-book-open"></i>
                </div> *@
                <div>
                    <h1 class="biblioteca-section-title ty-page-title">Biblioteca de ACC</h1>
                    <p class="biblioteca-section-description ty-paragraph">
                        Explora documentación, ejercicios y proyectos organizados en capítulos.
                    </p>
                </div>
            </div>

            <div class="biblioteca-header-divider" aria-hidden="true"></div>

            <ViewToggle Filtros="@filtros"
                        OnFiltrosCambiados="OnFiltrosCambiados" />

        </div>

        @if (cargando)
        {
            <div class="biblioteca-loader" style="display:block;">
                <div class="biblioteca-loader-spinner"></div>
                <p class="biblioteca-loader-text ty-muted">Cargando contenido…</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="biblioteca-error-state">
                <div class="biblioteca-error-icon" aria-hidden="true">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <h3 class="biblioteca-empty-title ty-section-title">Error al cargar</h3>
                <p class="biblioteca-empty-description ty-muted">@mensajeError</p>
                <button class="btn btn--primary biblioteca-error-retry" @onclick="RecargarContenido">
                    <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
                    Reintentar
                </button>
            </div>
        }
        else if (todosLosCapitulos?.Data != null)
        {
            <DocList capitulos="@todosLosCapitulos.Data"
                     Filtros="@filtros" />
        }
        else
        {
            <div class="biblioteca-empty-state">
                <div class="biblioteca-empty-icon" aria-hidden="true">
                    <i class="fa-regular fa-folder-open"></i>
                </div>
                <h3 class="biblioteca-empty-title ty-section-title">Sin contenido disponible</h3>
                <p class="biblioteca-empty-description ty-muted">No hay capítulos publicados todavía.</p>
            </div>
        }

    </main>

    <SidebarFiltros OnFiltrosCambiados="OnFiltrosCambiados"
                    Filtros="@filtros" />

</div>
@code {
    //private List<string> filtrosSeleccionados = new();
    private BibliotecaFiltros filtros = new();
    private ServiceResult<List<CapituloDto>>? todosLosCapitulos;
    private bool cargando = true;
    private string? mensajeError;

    protected override async Task OnInitializedAsync()
        => await CargarContenido();

    private async Task CargarContenido()
    {
        try
        {
            cargando = true;
            mensajeError = null;

            todosLosCapitulos = await BibliotecaService.ObtenerCapitulosAsync();

            if (!todosLosCapitulos.Success)
                mensajeError = todosLosCapitulos.Message ?? "Error desconocido al cargar el contenido";
        }
        catch (Exception ex)
        {
            mensajeError = "Error de conexión. Por favor, intenta más tarde.";
            Console.WriteLine($"Excepción en CargarContenido: {ex.Message}");
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task RecargarContenido() => await CargarContenido();

    private void OnFiltrosCambiados(BibliotecaFiltros nuevos)
    {
        filtros = nuevos ?? new BibliotecaFiltros();
        StateHasChanged(); 
    }
}
