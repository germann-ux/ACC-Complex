    protected override async Task OnInitializedAsync()
    {
        AgendaNotifier.Changed += HandleAgendaChanged;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            MostrarErrorAuth();
            return;
        }

        var accessToken = ApiJwtTokenService.TryCreateAccessToken(user);
        if (!string.IsNullOrWhiteSpace(accessToken))
        {
            cliente.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
        }

        userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value
            ?? user.FindFirst("sub")?.Value;

        await CargarTareasAsync(cts.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || preferenciasCargadas)
        {
            return;
        }

        preferenciasCargadas = true;
        await CargarPreferenciasAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CargarPreferenciasAsync()
    {
        try
        {
            var filtroGuardado = await JS.InvokeAsync<string?>("localStorage.getItem", LocalStorageFiltroKey);
            if (!string.IsNullOrWhiteSpace(filtroGuardado) && Enum.TryParse<AgendaWorkFilter>(filtroGuardado, out var filtro))
            {
                filtroActivo = filtro;
            }

            var agrupacionGuardada = await JS.InvokeAsync<string?>("localStorage.getItem", LocalStorageAgrupacionKey);
            if (!string.IsNullOrWhiteSpace(agrupacionGuardada) && Enum.TryParse<AgendaGrouping>(agrupacionGuardada, out var agrupacion))
            {
                agrupacionActiva = agrupacion;
            }
        }
        catch
        {
            // Ignore persistence errors.
        }
    }

    private async Task GuardarPreferenciasAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", LocalStorageFiltroKey, filtroActivo.ToString());
            await JS.InvokeVoidAsync("localStorage.setItem", LocalStorageAgrupacionKey, agrupacionActiva.ToString());
        }
        catch
        {
            // Ignore persistence errors.
        }
    }

    private async Task CambiarFiltroAsync(AgendaWorkFilter filtro)
    {
        if (filtroActivo == filtro)
        {
            return;
        }

        filtroActivo = filtro;
        await GuardarPreferenciasAsync();
    }

    private async Task CambiarAgrupacionAsync(AgendaGrouping agrupacion)
    {
        if (agrupacionActiva == agrupacion)
        {
            return;
        }

        agrupacionActiva = agrupacion;
        await GuardarPreferenciasAsync();
    }

    private async Task CargarTareasAsync(CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            MostrarErrorAuth();
            return;
        }

        isLoadingTareas = true;
        errorMessageTareas = null;

        try
        {
            var overview = await AgendaClient.GetOverviewAsync(token);
            tareasPersonales = overview.Personales;
            tareasAsignadas = overview.Asignadas;

            if (pendingDeletePersonalId.HasValue)
            {
                tareasPersonales = tareasPersonales
                    .Where(t => t.TareaPersonalId != pendingDeletePersonalId.Value)
                    .ToList();
            }

            if (!string.IsNullOrWhiteSpace(overview.ErrorMessage))
            {
                errorMessageTareas = overview.ErrorMessage;
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            MostrarErrorAuth();
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
            // Ignore cancellation on dispose.
        }
        catch (Exception ex)
        {
            errorMessageTareas = $"Error al cargar tareas: {ex.Message}";
        }
        finally
        {
            isLoadingTareas = false;
        }
    }

    private async Task RefrescarTareasAsync()
    {
        await CargarTareasAsync(cts.Token);
        ignoreNextNotification = true;
        AgendaNotifier.NotifyChanged();
        await InvokeAsync(StateHasChanged);
    }

    private void HandleAgendaChanged()
    {
        if (ignoreNextNotification)
        {
            ignoreNextNotification = false;
            return;
        }

        _ = InvokeAsync(async () =>
        {
            if (!isAuthError && !cts.IsCancellationRequested)
            {
                await CargarTareasAsync(cts.Token);
                StateHasChanged();
            }
        });
    }

    private IEnumerable<AgendaTaskItem> FiltrarItems(IEnumerable<AgendaTaskItem> items)
        => items
            .Where(item => CumpleFiltro(item, filtroActivo))
            .Where(item => !pendingDeletePersonalId.HasValue || !item.EsPersonal || item.PersonalId != pendingDeletePersonalId.Value)
            .OrderBy(item => item.FechaLimite.HasValue ? 0 : 1)
            .ThenBy(item => item.FechaLimite.HasValue ? ToLocal(item.FechaLimite.Value) : DateTime.MaxValue)
            .ThenBy(item => item.Titulo);

    private IEnumerable<AgendaDueGroup> CrearGruposPorVencimiento(IEnumerable<AgendaTaskItem> items)
    {
        var vencidas = new List<AgendaTaskItem>();
        var hoy = new List<AgendaTaskItem>();
        var proximas = new List<AgendaTaskItem>();
        var sinFecha = new List<AgendaTaskItem>();
        var completadas = new List<AgendaTaskItem>();

        foreach (var item in items)
        {
            if (item.Completada)
            {
                completadas.Add(item);
                continue;
            }

            if (!item.FechaLimite.HasValue)
            {
                sinFecha.Add(item);
                continue;
            }

            var fecha = ToLocal(item.FechaLimite.Value).Date;
            if (fecha < DateTime.Today)
            {
                vencidas.Add(item);
            }
            else if (fecha == DateTime.Today)
            {
                hoy.Add(item);
            }
            else
            {
                proximas.Add(item);
            }
        }

        if (vencidas.Count > 0)
        {
            yield return new AgendaDueGroup("Vencidas", vencidas);
        }

        if (hoy.Count > 0)
        {
            yield return new AgendaDueGroup("Hoy", hoy);
        }

        if (proximas.Count > 0)
        {
            yield return new AgendaDueGroup("Proximas", proximas);
        }

        if (sinFecha.Count > 0)
        {
            yield return new AgendaDueGroup("Sin fecha", sinFecha);
        }

        if (completadas.Count > 0)
        {
            yield return new AgendaDueGroup("Completadas", completadas);
        }
    }

    private int TotalPorFiltro(AgendaWorkFilter filtro)
        => TodosLosItems.Count(item => CumpleFiltro(item, filtro));

    private static bool CumpleFiltro(AgendaTaskItem item, AgendaWorkFilter filtro)
    {
        var fecha = item.FechaLimite.HasValue ? ToLocal(item.FechaLimite.Value).Date : (DateTime?)null;
        var hoy = DateTime.Today;

        return filtro switch
        {
            AgendaWorkFilter.Hoy => !item.Completada && fecha == hoy,
            AgendaWorkFilter.Proximas => !item.Completada && fecha.HasValue && fecha > hoy,
            AgendaWorkFilter.Vencidas => !item.Completada && fecha.HasValue && fecha < hoy,
            AgendaWorkFilter.Completadas => item.Completada,
            AgendaWorkFilter.Asignadas => !item.EsPersonal,
            AgendaWorkFilter.Personales => item.EsPersonal,
            AgendaWorkFilter.Recordatorios => !item.Completada && item.FechaLimite.HasValue,
            _ => true
        };
    }

    private static string NombreFiltro(AgendaWorkFilter filtro) => filtro switch
    {
        AgendaWorkFilter.Hoy => "Hoy",
        AgendaWorkFilter.Proximas => "Proximas",
        AgendaWorkFilter.Vencidas => "Vencidas",
        AgendaWorkFilter.Completadas => "Completadas",
        AgendaWorkFilter.Asignadas => "Asignadas",
        AgendaWorkFilter.Personales => "Personales",
        AgendaWorkFilter.Recordatorios => "Recordatorios",
        _ => "Todo"
    };

