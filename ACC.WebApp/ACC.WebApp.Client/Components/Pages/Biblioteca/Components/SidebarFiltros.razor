@* SidebarFiltros.razor *@

@rendermode InteractiveServer

@using ACC.Shared.Enums
@using ACC.Shared.Core

<aside class="biblioteca-sidebar" role="complementary" aria-label="Filtros de la biblioteca">

    <div class="biblioteca-sidebar-header">
        <div class="sf-header-inner">
            <i class="fa-solid fa-sliders sf-header-icon" aria-hidden="true"></i>
            <h2 class="biblioteca-sidebar-title">Filtros</h2>
        </div>

        @{
            var totalActivos = Filtros.Tipos.Count + Filtros.Niveles.Count + Filtros.Dificultades.Count;
        }
        @if (totalActivos > 0)
        {
            <button class="sf-clear-btn ty-muted" @onclick="LimpiarFiltros" title="Limpiar todos los filtros">
                <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                <span>@totalActivos</span>
            </button>
        }
    </div>

    <div class="biblioteca-sidebar-content">

        <!-- ── TIPOS ──────────────────────────────── -->
        <div class="biblioteca-filter-group biblioteca-filter-group-tipos">
            <div class="biblioteca-filter-title" @onclick="() => ToggleGrupo(nameof(TipoContenidoCapitulo))">
                <div class="sf-group-label">
                    <i class="fa-regular fa-file-lines sf-group-icon" aria-hidden="true"></i>
                    <span>Tipo de contenido</span>
                </div>
                <div class="sf-group-right">
                    @if (Filtros.Tipos.Count > 0)
                    {
                        <span class="sf-badge">@Filtros.Tipos.Count</span>
                    }
                    <i class="fa-solid @(ExpandTipo ? "fa-chevron-up" : "fa-chevron-down") biblioteca-filter-caret" aria-hidden="true"></i>
                </div>
            </div>

            @if (ExpandTipo)
            {
                <div class="biblioteca-filter-items">
                    @foreach (var t in Tipos)
                    {
                        var activo = Filtros.Tipos.Contains(t);
                        <div class="biblioteca-filter-item @(activo ? "active" : "")"
                             @onclick="() => ToggleTipo(t)"
                             role="checkbox"
                             aria-checked="@activo.ToString().ToLower()">
                            <i class="fa-solid @(activo ? "fa-circle-check" : "fa-circle") biblioteca-filter-icon" aria-hidden="true"></i>
                            <span>@EnumDisplay.Name(t)</span>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ── NIVELES ────────────────────────────── -->
        <div class="biblioteca-filter-group biblioteca-filter-group-niveles">
            <div class="biblioteca-filter-title" @onclick="() => ToggleGrupo(nameof(NivelContenido))">
                <div class="sf-group-label">
                    <i class="fa-regular fa-chart-bar sf-group-icon" aria-hidden="true"></i>
                    <span>Nivel</span>
                </div>
                <div class="sf-group-right">
                    @if (Filtros.Niveles.Count > 0)
                    {
                        <span class="sf-badge">@Filtros.Niveles.Count</span>
                    }
                    <i class="fa-solid @(ExpandNivel ? "fa-chevron-up" : "fa-chevron-down") biblioteca-filter-caret" aria-hidden="true"></i>
                </div>
            </div>

            @if (ExpandNivel)
            {
                <div class="biblioteca-filter-items">
                    @foreach (var n in Niveles)
                    {
                        var activo = Filtros.Niveles.Contains(n);
                        <div class="biblioteca-filter-item @(activo ? "active" : "")"
                             @onclick="() => ToggleNivel(n)"
                             role="checkbox"
                             aria-checked="@activo.ToString().ToLower()">
                            <i class="fa-solid @(activo ? "fa-circle-check" : "fa-circle") biblioteca-filter-icon" aria-hidden="true"></i>
                            <span>@EnumDisplay.Name(n)</span>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ── DIFICULTAD ─────────────────────────── -->
        <div class="biblioteca-filter-group biblioteca-filter-group-dificultad">
            <div class="biblioteca-filter-title" @onclick="() => ToggleGrupo(nameof(DificultadContenido))">
                <div class="sf-group-label">
                    <i class="fa-solid fa-fire sf-group-icon" aria-hidden="true"></i>
                    <span>Dificultad</span>
                </div>
                <div class="sf-group-right">
                    @if (Filtros.Dificultades.Count > 0)
                    {
                        <span class="sf-badge">@Filtros.Dificultades.Count</span>
                    }
                    <i class="fa-solid @(ExpandDificultad ? "fa-chevron-up" : "fa-chevron-down") biblioteca-filter-caret" aria-hidden="true"></i>
                </div>
            </div>

            @if (ExpandDificultad)
            {
                <div class="biblioteca-filter-items">
                    @foreach (var d in Dificultades)
                    {
                        var activo = Filtros.Dificultades.Contains(d);
                        <div class="biblioteca-filter-item @(activo ? "active" : "")"
                             @onclick="() => ToggleDificultad(d)"
                             role="checkbox"
                             aria-checked="@activo.ToString().ToLower()">
                            <i class="fa-solid @(activo ? "fa-circle-check" : "fa-circle") biblioteca-filter-icon" aria-hidden="true"></i>
                            <span>@EnumDisplay.Name(d)</span>
                        </div>
                    }
                </div>
            }
        </div>

    </div>
</aside>
@code {
    [Parameter, EditorRequired] public BibliotecaFiltros Filtros { get; set; } = default!;
    [Parameter] public EventCallback<BibliotecaFiltros> OnFiltrosCambiados { get; set; }

    private bool ExpandTipo = true;
    private bool ExpandNivel = true;
    private bool ExpandDificultad = true;

    private static readonly TipoContenidoCapitulo[] Tipos =
        Enum.GetValues<TipoContenidoCapitulo>().OrderBy(x => (int)x).ToArray();

    private static readonly NivelContenido[] Niveles =
        Enum.GetValues<NivelContenido>().OrderBy(x => (int)x).ToArray();

    private static readonly DificultadContenido[] Dificultades =
        Enum.GetValues<DificultadContenido>().OrderBy(x => (int)x).ToArray();

    private void ToggleGrupo(string nombre)
    {
        if (nombre == nameof(TipoContenidoCapitulo)) ExpandTipo = !ExpandTipo;
        if (nombre == nameof(NivelContenido)) ExpandNivel = !ExpandNivel;
        if (nombre == nameof(DificultadContenido)) ExpandDificultad = !ExpandDificultad;
    }

    private async Task ToggleTipo(TipoContenidoCapitulo t)
    {
        var nuevo = Filtros.Clone();
        if (!nuevo.Tipos.Add(t)) nuevo.Tipos.Remove(t);
        await OnFiltrosCambiados.InvokeAsync(nuevo);
    }

    private async Task ToggleNivel(NivelContenido n)
    {
        var nuevo = Filtros.Clone();
        if (!nuevo.Niveles.Add(n)) nuevo.Niveles.Remove(n);
        await OnFiltrosCambiados.InvokeAsync(nuevo);
    }

    private async Task ToggleDificultad(DificultadContenido d)
    {
        var nuevo = Filtros.Clone();
        if (!nuevo.Dificultades.Add(d)) nuevo.Dificultades.Remove(d);
        await OnFiltrosCambiados.InvokeAsync(nuevo);
    }

    private Task LimpiarFiltros()
        => OnFiltrosCambiados.InvokeAsync(new BibliotecaFiltros());
}
