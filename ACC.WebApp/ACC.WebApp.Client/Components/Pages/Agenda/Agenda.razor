    private async Task CrearTareaPersonalAsync()
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            return;
        }

        showCreateValidation = true;
        if (string.IsNullOrWhiteSpace(nuevoTitulo))
        {
            actionMessage = null;
            return;
        }

        actionMessage = null;
        isActionBusy = true;
        try
        {
            var dto = new TareaPersonalDto
            {
                TareaPersonalTitulo = nuevoTitulo.Trim(),
                TareaPersonalDescripcion = string.IsNullOrWhiteSpace(nuevaDescripcion) ? null : nuevaDescripcion.Trim(),
                TareaPersonalFechaLimite = usarNuevaFechaLimite 
                    ? DateTime.SpecifyKind(nuevaFechaLimiteLocal, DateTimeKind.Local).ToUniversalTime() 
                    : null,
                Completada = false
            };

            var response = await AgendaClient.CreatePersonalAsync(dto, cts.Token);
            if (response?.Success == true)
            {
                var nuevaId = response.Data?.TareaPersonalId;

                SetActionMessage("Tarea personal creada.", ok: true);
                CerrarModalCrearForzado();
                await RefrescarTareasAsync();

                if (nuevaId.HasValue)
                {
                    await EnfocarTareaPersonalAsync(nuevaId.Value);
                }
            }
            else
            {
                SetActionMessage(response?.Message ?? "No se pudo crear la tarea.", ok: false);
            }
        }
        catch (OperationCanceledException) when (cts.IsCancellationRequested)
        {
            // Ignore cancellation on dispose.
        }
        catch (Exception ex)
        {
            SetActionMessage($"Error al crear tarea: {ex.Message}", ok: false);
        }
        finally
        {
            isActionBusy = false;
        }
    }

    private void AplicarFechaRapida(int dias)
    {
        var horaBase = nuevaFechaLimiteLocal.TimeOfDay;
        if (horaBase == TimeSpan.Zero)
        {
            horaBase = DateTime.Now.TimeOfDay;
        }

        var propuesta = DateTime.Today.AddDays(dias).Add(horaBase);
        if (propuesta <= DateTime.Now)
        {
            propuesta = DateTime.Now.AddMinutes(30);
        }

        nuevaFechaLimiteLocal = propuesta;
    }

    private bool EsFechaRapidaActiva(int dias)
        => nuevaFechaLimiteLocal.Date == DateTime.Today.AddDays(dias);

    private string FechaPresetClass(int dias)
        => EsFechaRapidaActiva(dias) ? "agenda-modal-preset active" : "agenda-modal-preset";

    private static string FormatearResumenFecha(DateTime fecha)
    {
        var dias = (fecha.Date - DateTime.Today).Days;

        if (dias < 0)
        {
            return $"Vence desde hace {Math.Abs(dias)} dias";
        }

        if (dias == 0)
        {
            return $"Vence hoy a las {fecha:HH:mm}";
        }

        if (dias == 1)
        {
            return $"Vence manana a las {fecha:HH:mm}";
        }

        if (dias <= 7)
        {
            return $"Vence en {dias} dias a las {fecha:HH:mm}";
        }

        return $"Vence el {fecha:dd/MM/yyyy} a las {fecha:HH:mm}";
    }

    private static string FormatearResumenPrioridad(DateTime fecha)
    {
        var dias = (fecha.Date - DateTime.Today).Days;

        if (dias < 0)
        {
            return "Aparecera como vencida al crearla, revisa si esa fecha sigue siendo correcta.";
        }

        if (dias == 0)
        {
            return "Se destacara en tu agenda de hoy para que la resuelvas primero.";
        }

        if (dias <= 3)
        {
            return "Entrara como una prioridad cercana dentro de tu semana.";
        }

        if (dias <= 7)
        {
            return "Quedara visible en tus proximas tareas y recordatorios.";
        }

        return "Quedara planificada sin competir con lo mas urgente.";
    }

